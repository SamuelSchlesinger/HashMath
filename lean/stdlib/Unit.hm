-- =====================================================================
-- Unit and Empty — Trivial types
-- =====================================================================

-----------------------------------------------------------------------
-- Unit (single inhabitant)
-----------------------------------------------------------------------

inductive Unit : Type where
  | unit : Unit

-----------------------------------------------------------------------
-- Empty (no inhabitants)
-----------------------------------------------------------------------

inductive Empty : Type where

def Empty.elim : ∀ (A : Type), Empty → A :=
  fun (A : Type) (h : Empty) =>
    Empty.rec.{1}
      (fun (_ : Empty) => A)
      h
